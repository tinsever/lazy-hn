          io.observe(a);
        });
      },50);
    }
    scan();
    if('MutationObserver'in window){
      new MutationObserver(scan).observe(document.documentElement,{childList:true,subtree:true});
    }
  }

  function applyDoc(href,html,push){
    if(push)history.pushState(null,'',href);
    document.open();
