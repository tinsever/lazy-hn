  function skey(h){return PREFIX+h;}
  function getDisk(h){
    try{return sessionStorage.getItem(skey(h));}catch(e){return null;}
  }
  function touch(h){
    try{
      var k=JSON.parse(sessionStorage.getItem(LRU_KEY)||'[]');
      k=k.filter(function(x){return x!==h;});
      k.unshift(h);
